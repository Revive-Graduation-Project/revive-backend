# ── Stripe (Payment Service) ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ── Local / Development Databases ──────────────────────────────────────────
# Define these to override the default local/container configurations if needed.
# Auth Service DB
AUTH_DB_URL=jdbc:postgresql://localhost:5431/auth_db
AUTH_DB_USERNAME=postgres
AUTH_DB_PASSWORD=postgres

# Client Service DB
CLIENT_DB_URL=jdbc:postgresql://localhost:5432/client_db
CLIENT_DB_USERNAME=postgres
CLIENT_DB_PASSWORD=postgres

# Inventory Service DB
INVENTORY_DB_URL=jdbc:postgresql://localhost:5433/inventory_db
INVENTORY_DB_USERNAME=postgres
INVENTORY_DB_PASSWORD=postgres

# Menu Management Service DB
MENU_DB_URL=jdbc:postgresql://localhost:5434/menu_db
MENU_DB_USERNAME=postgres
MENU_DB_PASSWORD=postgres

# Order Service DB
ORDER_DB_URL=jdbc:postgresql://localhost:5435/order_db
